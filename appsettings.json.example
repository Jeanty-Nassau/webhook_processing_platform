{
	"ConnectionStrings": {
		"DefaultConnection": "Host=your-database-host;Database=your-database-name;Username=your-username;Password=your-password;SSL Mode=Require;Trust Server Certificate=true"
	},
	"WebhookSignatureSecret": "your-webhook-secret-here",
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning"
		}
	},
	"AllowedHosts": "*"
}
